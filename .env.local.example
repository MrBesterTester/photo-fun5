# Option 1: Direct Google Gemini API (original method)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: TrueFoundry AI Gateway (recommended for production)
# Get your credentials from: https://app.truefoundry.com
# Base URL is typically: https://api.truefoundry.com or https://{workspace}.api.truefoundry.com
TRUEFOUNDRY_BASE_URL=https://api.truefoundry.com
# Get your Personal Access Token from: Settings → API Keys in TrueFoundry dashboard
TRUEFOUNDRY_API_KEY=your_truefoundry_api_key_here
# Model identifier format: {workspace}:{provider}:{model-name}
# Example: sak-consulting:google-gemini:google-gemini
TRUEFOUNDRY_MODEL=sak-consulting:google-gemini:google-gemini
